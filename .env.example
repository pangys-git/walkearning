# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_MAPS_API_KEY: Required for rendering Google Maps and routing.
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# GOOGLE_SERVICE_ACCOUNT_EMAIL: Required for writing to Google Sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"

# GOOGLE_PRIVATE_KEY: Required for writing to Google Sheets
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# GOOGLE_SHEET_ID: The ID of the Google Sheet to write to (from the URL)
GOOGLE_SHEET_ID="YOUR_SHEET_ID"
